{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Comment List",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["id", "postId", "name", "email", "body"],
    "properties": {
      "id":     { "type": "integer" },
      "postId": { "type": "integer" },
      "name":   { "type": "string" },
      "email":  { "type": "string", "format": "email" },
      "body":   { "type": "string" }
    },
    "additionalProperties": false
  }
}