{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Photo List",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["id", "albumId", "title", "url", "thumbnailUrl"],
    "properties": {
      "id":           { "type": "integer" },
      "albumId":      { "type": "integer" },
      "title":        { "type": "string" },
      "url":          { "type": "string", "format": "uri" },
      "thumbnailUrl": { "type": "string", "format": "uri" }
    },
    "additionalProperties": false
  }
}